generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== OTP ====================
enum OtpType {
  ACCOUNT_VERIFY
  FORGOT_PASSWORD
}


model Otp {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  email      String    @unique
  code       Int
  type       OtpType   
  isUsed     Boolean   @default(false)
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  attempts   Int       @default(0)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updateAt   DateTime  @updatedAt

  @@map("otps")
}


// ============================= User model =========================
enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserRole {
  USER
  ADMIN
}

enum UserTier {
  FREE
  PREMIUM
}

enum UserStatus {
  UNBLOCK
  BLOCKED
}

model User {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  firstName       String
  lastName        String
  email           String       @unique
  password        String
  avatar          String?
  role            UserRole     @default(USER)
  status          UserStatus   @default(UNBLOCK)
  tier            UserTier     @default(FREE)
  provider        AuthProvider @default(EMAIL)
  isEmailVerified Boolean      @default(false)

  companyMember   CompanyMember?
  subscriptions   Subscription[]
  transactions    Transaction[]


  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("users")
}

// ========================= Company =========================
model Company {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String       @unique
  location        String
  companyMembers  CompanyMember[]
  rawMaterials    RawMaterial[]
  products        Product[]
  customers       Customer[]

  @@map("companies")
}

enum MemberRole {
  owner
  member
}

enum MemberStatus {
  active
  inactive
}

model CompanyMember {
  id              String       @id @map("_id") @db.ObjectId
  companyId       String       @db.ObjectId
  role            MemberRole
  status          MemberStatus @default(active)

  user            User         @relation(fields: [id], references: [id],onDelete: Cascade)
  company         Company      @relation(fields: [companyId], references: [id],onDelete: Cascade)

  @@map("company_members")
}

// ======================== Raw Material ======================
model RawMaterial {
  id                    String       @id @default(auto()) @map("_id") @db.ObjectId
  chemicalName          String
  chemicalType          String // Corrosion Inhibitor, Biocide,Scale Inhibitor,  Dispersant, Other 
  supplierName          String
  dosageRate            String // ppm, mg/L
  dosageType            String // ppm, mg/L
  feedFrequency         String // Daily, weekly
  safetyClassification  String // Hazardous, Non-hazardous
  instructions          String
  isActive              Boolean      @default(true)
  companyId             String       @db.ObjectId

  company         Company      @relation(fields: [companyId], references: [id],onDelete: Cascade)
 
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("raw_materials")
}

// =========================== Product ========================
model Product {
  id                        String      @id @default(auto()) @map("_id") @db.ObjectId
  name                      String
  manufacturer              String
  productCategory           String // Corrosion Inhibitor, Biocide,Scale Inhibitor,  Dispersant, Other
  intendedUse               String // Cooling, Boiler, Process Water
  operatingPhRangeMin       Int
  operatingPhRangeMax       Int
  temperatureTolerance      String 
  maximumHardnessAllowed    String // e.g Treatment Chemical, Testing Reagent, Cleaning Agent, Additive
  compatibilityNote         String
  costPerUnit               Int 
  averageMonthlyConsumption String // L, kg, gal
  consumptionType           String
  replacementFrequency      String // e.g monthly, quarterly, semi-annually, annually
  isActive                  Boolean      @default(true)
  companyId                 String       @db.ObjectId

  company         Company      @relation(fields: [companyId], references: [id],onDelete: Cascade)

  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@map("products")
}

// =========================== Customer ========================
model Customer { 
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  siteName        String
  location        String
  address         String
  contactPerson   String
  contactEmail    String
  contactPhone    String
  isActive        Boolean      @default(true)
  companyId       String       @db.ObjectId

  company         Company      @relation(fields: [companyId], references: [id],onDelete: Cascade)

  assets          Asset[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("customers")
}


model Asset {
  id                    String       @id @default(auto()) @map("_id") @db.ObjectId
  name                  String
  type                  String       // e.g Cooling Tower, Evaporative Condenser, Once-Through Cooling, Seawater Cooling Tower, Adiabatic Cooler
  location              String
  installationDate      String
  systemVolume          String
  flowRate              String
  operatingTemperature  String
  cyclesOfConcentration String
  materialType          String // e.g Carbon Steel, Stainless Steel, Copper, Galvanized Steel
  currentCondition      String // e.g 
  knownIssues           String
  customerId            String       @db.ObjectId

  customer              Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("assets")
}


// =========================== Subscription ==========================

enum PlanName {
  BASIC
  ADVANCED
  EXPERT
}

model Plan {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            PlanName
  isActive        Boolean      @default(true)          
  monthlyPrice    Int
  annualPrice     Int
  description     String
  maxReports      Int
  maxAccounts     Int
  features        Json

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("plans")
}

// ===================== Subscription ===========================
enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INCOMPLETE
  TRIALING
}

model Subscription {
  id                    String             @id @default(auto()) @map("_id") @db.ObjectId
  userId                String             @db.ObjectId @unique
  stripeCustomerId      String             @unique
  stripeSubscriptionId  String?            @unique   // set by webhook
  planDetails           Json                  
  status                SubscriptionStatus @default(PAST_DUE)

  startDate DateTime
  endDate   DateTime
  
  // Optional lifecycle flags
  cancelAtPeriodEnd      Boolean  @default(false)
  canceledAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User               @relation(fields: [userId], references: [id])
  transactions          Transaction[]

  @@index([status])
  @@map("subscriptions")
}

// ================ Transaction ==============================
enum TransactionStatus {
  SUCCEEDED
  FAILED
  REFUNDED
}

model Transaction {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  reference         String   @unique  // paymentIntentId
  amount            Int
  currency          String
  status            TransactionStatus
  createdAt         DateTime @default(now())
  subscriptionId    String

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  user       User     @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model RecentActivity {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  actionType    String
  message       String?
  details       Json?
  createdAt DateTime @default(now())

  @@map("recent_activities")
}
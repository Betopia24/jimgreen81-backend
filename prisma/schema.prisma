generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== OTP ====================
enum OtpType {
  ACCOUNT_VERIFY
  FORGOT_PASSWORD
}


model Otp {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  email      String    
  code       Int
  type       OtpType   
  isUsed     Boolean   @default(false)
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  attempts   Int       @default(0)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updateAt   DateTime  @updatedAt

  @@map("otps")
}


// ============================= User model =========================
enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserRole {
  USER
  ADMIN
}

enum UserTier {
  FREE
  PREMIUM
}

enum UserStatus {
  UNBLOCK
  BLOCKED
}

model User {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  firstName       String
  lastName        String
  email           String       @unique
  password        String
  avatar          String?
  role            UserRole     @default(USER)
  status          UserStatus   @default(UNBLOCK)
  tier            UserTier     @default(FREE)
  provider        AuthProvider @default(EMAIL)
  isEmailVerified Boolean      @default(false)

  companyMember   CompanyMember?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("users")
}

// ========================= Company =========================
model Company {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String?       @unique
  location        String
  isActive        Boolean      @default(true)
  companyMembers  CompanyMember[]
  customers       Customer[]
  rawMaterials    RawMaterial[]
  products        Product[]
  waterReports    WaterReport[]
  analysis        SaturationAnalysis[]

  subscriptions   Subscription[]
  transactions    Transaction[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("companies")
}

enum MemberRole {
  owner
  member
}

enum MemberStatus {
  active
  inactive
}

model CompanyMember {
  id              String       @id @map("_id") @db.ObjectId
  companyId       String       @db.ObjectId
  role            MemberRole
  status          MemberStatus @default(active)

  user            User         @relation(fields: [id], references: [id],onDelete: Cascade)
  company         Company?      @relation(fields: [companyId], references: [id],onDelete: Cascade)

  @@map("company_members")
}

// ======================== Raw Material ======================
model RawMaterial {
  id                              String       @id @default(auto()) @map("_id") @db.ObjectId
  commonName                      String
  manufacturer                    String
  manufacturerProductName         String
  activeComponentName             String
  activePercentage                Int
  activePercentageChemicalFormula String
  formulas                        RawMaterialFormula[]
  estimatedCost                   Int
  bandUpperCushion                String
  bandLowerCushion                String
  communityVisibility             String
  additionalInformation           String?  
  isActive                        Boolean      @default(true)
  companyId                       String       @db.ObjectId
  company         Company      @relation(fields: [companyId], references: [id],onDelete: Cascade)
 
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("raw_materials")
}

type RawMaterialFormula {
  salToInhibit                    String
  applicableIonicStrength         String
  formulaForInhibitionPerformance String
}


// =========================== Product ========================
model Product {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId

  productName               String
  manufacturerName          String

  rawMaterials              Json     // array of raw materials with snapshot

  waterPercentage           Float    @default(0)

  calculatedProductCost     Float
  manualCostOverride        Float?
  finalProductCost          Float

  productPrice              Float

  communityVisibility       String
  isActive                  Boolean  @default(true)

  companyId                 String   @db.ObjectId
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("products")
}

// =========================== Customer ========================
model Customer { 
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  siteName        String
  location        String
  address         String
  contactPerson   String
  contactEmail    String
  contactPhone    String
  isActive        Boolean      @default(true)
  companyId       String       @db.ObjectId

  company         Company      @relation(fields: [companyId], references: [id],onDelete: Cascade)

  assets          Asset[]
  waterReports    WaterReport[]
  analysis        SaturationAnalysis[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("customers")
}


model Asset {
  id                                    String       @id @default(auto()) @map("_id") @db.ObjectId
  customerId                            String       @db.ObjectId
  name                                  String
  type                                  String
  towerType                             String?
  fillType                              String?
  criticalHeatExchangerDesign           String?
  recirculationRate                     Int?
  recirculationRateType                 String?
  tonnageOfCooling                      Int?
  systemVolume                          Int?
  systemVolumeType                      String?
  supplyTemperature                     Int?
  supplyTemperatureType                 String?
  returnTemperature                     Int?
  returnTemperatureType                 String?
  deltaTemperature                      Int?
  systemMetallurgy                      String[]     @default([])
  systemMaterials                       String[]     @default([])
  hottestSkinTemperature                Int?
  hottestSkinTemperatureType            String?
  criticalHeatExchangerFlowRate         Int?
  criticalHeatExchangerFlowRateType     String?

  // 3rd assets
  flowRate                              Int?
  flowRateType                          String?
  dischargeTemperature                  Int?
  dischargeTemperatureType              String?
  criticalCooling                       String?
  criticalFlowRate                      Int?
  criticalFlowRateType                  String?

  NSFStandard60                         Boolean?     @default(false)
  NSFG5G7                               Boolean?     @default(false)
  GRAS                                  Boolean?     @default(false)
  environmentalDischargeLimits          Json?
  productPrograms                       Json?
  controlVariablesAndTargets            Json?

  waterReports            WaterReport[]
  saturationAnalyses      SaturationAnalysis[]

  customer                              Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt                             DateTime     @default(now())
  updatedAt                             DateTime     @updatedAt

  @@map("assets")
}

// =========================== Water Report From AI ==========================
model WaterReport {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  
  assetId                String   @db.ObjectId
  customerId             String   @db.ObjectId
  companyId              String   @db.ObjectId

  name                   String

  sampleLocation         String?
  sampleDate             String?
  originalFilename       String?

  aiReportId             String  @unique
  extractedParameters    Json?
  parameterGraph         Json?
  chemicalStatus         Json?
  totalScore             Json?
  qualityReport          Json?
  chemicalComposition    Json?
  biologicalIndicators   Json?
  complianceChecklist    Json?
  contaminationRisk      Json?

  // relation
  asset                  Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  customer               Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  saturationAnalyses     SaturationAnalysis[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("water_upload_reports")
}

model SaturationAnalysis {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  companyId       String   @db.ObjectId
  customerId      String   @db.ObjectId
  assetId         String   @db.ObjectId
  waterReportId   String   @db.ObjectId

  name            String

  // Selected treatment
  productId       String?  @db.ObjectId
  rawMaterialId   String?  @db.ObjectId

  // AI RESPONSE (IMPORTANT)
  aiResponse      Json     // full AI output

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // relations
  waterReport     WaterReport @relation(fields: [waterReportId], references: [id])
  company         Company     @relation(fields: [companyId], references: [id])
  customer        Customer    @relation(fields: [customerId], references: [id])
  asset           Asset       @relation(fields: [assetId], references: [id])

  @@map("saturation_analyses")
}

// =========================== PLAN ==========================
enum PlanName {
  BASIC
  ADVANCED
  EXPERT
}

model Plan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        PlanName
  isActive    Boolean  @default(true)
  monthlyPrice Int
  annualPrice  Int
  description String
  maxReports  Int
  maxAccounts Int
  features    String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// =========================== SUBSCRIPTION ==========================
enum SubscriptionStatus {
  ACTIVE
  INCOMPLETE
  CANCELED
  EXPIRED
}

model Subscription {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  companyId         String             @db.ObjectId @unique
  paymentIntentId   String             @unique
  planId            String             @db.ObjectId
  planType          String             // monthly / annually
  status            SubscriptionStatus @default(INCOMPLETE)

  // plan snapshot
  planSnapshot      Json

  startDate         DateTime
  endDate           DateTime
  canceledAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company    @relation(fields: [companyId], references: [id])
  plan              Plan       @relation(fields: [planId], references: [id])
  transactions      Transaction[]

  @@map("subscriptions")
}

// =========================== TRANSACTION ==========================
enum TransactionStatus {
  SUCCEEDED
  FAILED
  REFUNDED
}

model Transaction {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId      String   @db.ObjectId
  subscriptionId String   @db.ObjectId
  reference      String   @unique // paymentIntentId
  amount         Int
  currency       String
  status         TransactionStatus
  createdAt      DateTime @default(now())

  company        Company         @relation(fields: [companyId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("transactions")
}


// =================== Recent Activity ======================
enum ActivityFor {
  SUPER_ADMIN
  COMPANY_OWNER
}

model RecentActivity {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  activityFor     ActivityFor
  message         String
  performerName   String
  performerImage  String?      
  details         Json?
  createdAt       DateTime @default(now())

  @@map("recent_activities")
}